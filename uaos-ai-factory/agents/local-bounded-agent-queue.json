{
  "status": "READY_LOCAL_ONLY",
  "mode": "LOCAL_ONLY",
  "externalAutomation": "BLOCKED",
  "rules": {
    "noTwentyFourHourAgents": true,
    "noOpenEndedAgents": true,
    "oneSmallTaskAtATime": true,
    "stopAfterReport": true,
    "ownerApprovalRequiredForRiskyTasks": true,
    "proprietaryAssetsAllowed": false,
    "realKeyboardWriterExportAllowed": false,
    "appJsxAllowed": false,
    "pushAllowed": false,
    "deployAllowed": false,
    "vercelAllowed": false,
    "paymentAllowed": false
  },
  "tasks": [
    {
      "id": "Agent-A",
      "title": "project docs consolidation",
