# UAOS production data/email integration example.
# Keep the real file private and outside source control.

NODE_ENV=production
UAOS_PRODUCTION_ACCOUNTS_PORT=3051
UAOS_PUBLIC_BASE_URL=https://your-domain.example

# Managed PostgreSQL:
UAOS_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
UAOS_DATABASE_SSL=true

# SMTP:
UAOS_SMTP_HOST=smtp.example.com
UAOS_SMTP_PORT=587
UAOS_SMTP_SECURE=false
UAOS_SMTP_USER=replace-me
UAOS_SMTP_PASSWORD=replace-me
UAOS_EMAIL_FROM=UAOS <no-reply@your-domain.example>
UAOS_SUPPORT_EMAIL=support@your-domain.example