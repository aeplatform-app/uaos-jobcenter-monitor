# UAOS production environment example.
# Never commit real secrets.

UAOS_PUBLIC_BASE_URL=https://example.com
UAOS_PAYMENT_PROVIDER=stripe-or-paypal
UAOS_PAYMENT_SECRET=server-side-secret-only
UAOS_LICENSE_SIGNING_SECRET=server-side-license-secret
UAOS_SUPPORT_EMAIL=support@example.com

# Set these only after real approval/testing.
UAOS_OFFICIAL_LEGAL_APPROVAL=false
UAOS_HARDWARE_VALIDATION_APPROVED=false
UAOS_WINDOWS_SIGNING_READY=false