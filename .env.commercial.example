# UAOS commercial backend example.
# Copy to a private environment file and replace every placeholder.
# Never commit real secrets.

UAOS_COMMERCIAL_PORT=3040
UAOS_PUBLIC_BASE_URL=https://example.com
UAOS_PAYMENT_PROVIDER=disabled
UAOS_PAYMENT_SECRET=replace-with-provider-webhook-secret
UAOS_LICENSE_SIGNING_SECRET=replace-with-long-random-license-secret
UAOS_ADMIN_SECRET=replace-with-long-random-admin-secret
UAOS_COMMERCIAL_STORAGE=development-memory
UAOS_SUPPORT_EMAIL=support@example.com