{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": true,
  "buildCommand": "node build-static.js",
  "outputDirectory": "dist",
  "installCommand": "echo no-install",
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/jobcenter", "destination": "/jobcenter/index.html" },
    { "source": "/jobcenter/", "destination": "/jobcenter/index.html" },
    { "source": "/status", "destination": "/status/index.html" },
    { "source": "/status/", "destination": "/status/index.html" }
  ]
}
