{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": true,
  "buildCommand": "echo static",
  "outputDirectory": "public",
  "installCommand": "echo no-install",
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/jobcenter",
      "destination": "/jobcenter/index.html"
    },
    {
      "source": "/jobcenter/",
      "destination": "/jobcenter/index.html"
    },
    {
      "source": "/status",
      "destination": "/status/index.html"
    },
    {
      "source": "/status/",
      "destination": "/status/index.html"
    }
  ]
}