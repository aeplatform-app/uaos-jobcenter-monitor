# UAOS Stripe production template.
# Never commit real values.

NODE_ENV=production
UAOS_STRIPE_SECRET_KEY=sk_test_replace_me
UAOS_STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Founders offer: first 3 paid months, then the regular price.
UAOS_STRIPE_FOUNDERS_SCHEDULE_ENABLED=false
UAOS_STRIPE_PRICE_CREATOR_INTRO=price_replace_studio_intro_799
UAOS_STRIPE_PRICE_CREATOR_REGULAR=price_replace_studio_regular_1299
UAOS_STRIPE_PRICE_PROFESSIONAL_INTRO=price_replace_pro_intro_1999
UAOS_STRIPE_PRICE_PROFESSIONAL_REGULAR=price_replace_pro_regular_2999

# Legacy single-price fallback. Used only when the founders schedule is disabled.
UAOS_STRIPE_PRICE_CREATOR=
UAOS_STRIPE_PRICE_PROFESSIONAL=

UAOS_STRIPE_AUTOMATIC_TAX=false
UAOS_STRIPE_ALLOW_PROMOTION_CODES=false

