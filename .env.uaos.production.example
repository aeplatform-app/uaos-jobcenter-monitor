# UAOS production activation template.
# Copy to .env.uaos.production.local and insert private values.
# Never commit the local file.

NODE_ENV=production
UAOS_PUBLIC_BASE_URL=https://replace-with-your-domain.example

# PostgreSQL
UAOS_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# SMTP
UAOS_SMTP_HOST=smtp.example.com
UAOS_SMTP_PORT=587
UAOS_SMTP_USER=replace_me
UAOS_SMTP_PASSWORD=replace_me
UAOS_SMTP_FROM=UAOS <no-reply@example.com>

# Stripe test mode first
UAOS_STRIPE_SECRET_KEY=sk_test_replace_me
UAOS_STRIPE_WEBHOOK_SECRET=whsec_replace_me
UAOS_STRIPE_FOUNDERS_SCHEDULE_ENABLED=true
UAOS_STRIPE_PRICE_CREATOR_INTRO=price_replace_studio_intro_799
UAOS_STRIPE_PRICE_CREATOR_REGULAR=price_replace_studio_regular_1299
UAOS_STRIPE_PRICE_PROFESSIONAL_INTRO=price_replace_pro_intro_1999
UAOS_STRIPE_PRICE_PROFESSIONAL_REGULAR=price_replace_pro_regular_2999
UAOS_STRIPE_AUTOMATIC_TAX=false
UAOS_STRIPE_ALLOW_PROMOTION_CODES=false

# Explicit approvals
UAOS_LEGAL_APPROVED=false
UAOS_PRIVACY_APPROVED=false
UAOS_TERMS_APPROVED=false

# Windows signing
UAOS_WINDOWS_SIGNING_CERTIFICATE=C:\secure\uaos-signing.pfx
UAOS_WINDOWS_SIGNING_PASSWORD=replace_me
