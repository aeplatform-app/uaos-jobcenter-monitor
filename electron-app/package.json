
{
"name":"uaos-desktop-shell",
"version":"0.1.0",
"main":"main.js",
"scripts":{
"start":"electron .",
"pack":"electron-builder --win portable"
},
"dependencies":{
"electron":"latest"
},
"devDependencies":{
"electron-builder":"latest"
},
"build":{
"appId":"com.uaos.hyperstation",
"productName":"UAOS HyperStation",
"directories":{
