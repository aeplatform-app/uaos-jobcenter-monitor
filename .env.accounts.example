# UAOS accounts/authentication example.
# Never commit real credentials or user data.

UAOS_ACCOUNTS_PORT=3041
UAOS_PUBLIC_BASE_URL=http://127.0.0.1:5173

# Development only:
UAOS_ACCOUNTS_STORAGE=local-json
UAOS_ACCOUNTS_DATA_FILE=C:\Users\YOUR_USER\AppData\Local\UAOS\accounts.dev.json

# Production placeholders:
UAOS_EMAIL_PROVIDER=
UAOS_EMAIL_FROM=
UAOS_DATABASE_URL=